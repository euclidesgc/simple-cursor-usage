{
  "name": "cursor-usage-for-teams",
  "displayName": "Cursor Usage for Teams",
  "description": "Show Cursor monthly usage for teams in the status bar.",
  "version": "0.1.2",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cursorUsageForTeams.refresh",
    "onCommand:cursorUsageForTeams.showDetails",
    "onCommand:cursorUsageForTeams.setToken",
    "onCommand:cursorUsageForTeams.clearToken"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorUsageForTeams.refresh",
        "title": "Cursor Monthly Usage: Refresh"
      },
      {
        "command": "cursorUsageForTeams.showDetails",
        "title": "Cursor Monthly Usage: Show Details"
      },
      {
        "command": "cursorUsageForTeams.setToken",
        "title": "Cursor Monthly Usage: Set Token"
      },
      {
        "command": "cursorUsageForTeams.clearToken",
        "title": "Cursor Monthly Usage: Clear Stored Token"
      }
    ],
    "configuration": {
      "title": "Cursor Monthly Usage",
      "properties": {
        "cursorUsageForTeams.apiBaseUrl": {
          "type": "string",
          "default": "https://cursor.com",
          "description": "Cursor web API origin for usage-summary requests. Must be HTTPS."
        },
        "cursorUsageForTeams.pollIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "description": "How often to refresh usage in the background."
        },
        "cursorUsageForTeams.displayFormat": {
          "type": "string",
          "default": "remaining",
          "enum": [
            "remaining",
            "fraction",
            "percent"
          ],
          "description": "Status bar format."
        },
        "cursorUsageForTeams.warningRemainingPercent": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 100,
          "description": "Warn when remaining usage is at or below this percent."
        },
        "cursorUsageForTeams.criticalRemainingPercent": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "maximum": 100,
          "description": "Show an error color when remaining usage is at or below this percent."
        },
        "cursorUsageForTeams.enableLocalTokenDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Read Cursor local state.vscdb to find the session token and user id."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "@types/sql.js": "^1.4.11"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
